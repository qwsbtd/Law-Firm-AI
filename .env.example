# Copy to .env and fill in real values
# Generate JWT secret: python -c "import secrets; print(secrets.token_hex(32))"

ANTHROPIC_API_KEY=sk-ant-...
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=8

# SQLite (persisted in Docker volume)
DATABASE_URL=sqlite:////app/data/law_firm.db

# ChromaDB persistent path (inside container)
CHROMA_PERSIST_PATH=/app/data/chroma

# Upload storage path (inside container)
UPLOADS_PATH=/app/data/uploads

# Seeded admin account (change password immediately after first login)
ADMIN_EMAIL=admin@lawfirm.com
ADMIN_PASSWORD=ChangeMe123!

# Optional: Slack notifications (leave blank to disable)
SLACK_WEBHOOK_URL=

# Optional: Email notifications (leave blank to disable)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFICATION_EMAIL_TO=

# Backend URL as seen from the frontend container
BACKEND_URL=http://backend:8000
